# =============================================================================
# AffordableStoreStuff — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# --- Authentication (Required) ---
# Secret used to sign JWT tokens. Must be a long, random string.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# --- Database (Required) ---
# Supabase connection pooler URL (Transaction mode, port 6543)
# Get this from: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# --- AI / OpenAI (Required for AI features) ---
# Your OpenAI API key
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
# OpenAI model to use (defaults to gpt-4o if not set)
AI_MODEL=gpt-4o
# Custom OpenAI-compatible base URL (leave blank for default OpenAI)
# AI_INTEGRATIONS_OPENAI_BASE_URL=

# --- Stripe (Required for payments) ---
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Get this from: Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Google Cloud Storage (Optional — for image uploads) ---
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-bucket-name
# PUBLIC_OBJECT_SEARCH_PATHS=public/images,public/assets
# PRIVATE_OBJECT_DIR=private

# --- Server (Local development only — not needed on Vercel) ---
# PORT=5000
# NODE_ENV=development
